{
  "manifest_version": 3,
  "name": "LinkedIn AI Commenter",
  "version": "1.2",
  "description": "Generate AI comments for LinkedIn posts using multimodal text and image pipeline.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "AI Comment Settings",
    "default_popup": "popup/popup.html"
  }
}